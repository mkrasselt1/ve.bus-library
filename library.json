{
  "name": "VEBus",
  "version": "1.0.0",
  "description": "ESP32 Arduino library for Victron Multiplus VE.Bus RS485 communication. Supports ESS power setpoint, sleep/wake commands, and battery/AC data readback.",
  "keywords": ["victron", "ve.bus", "multiplus", "ess", "inverter", "charger", "rs485", "esp32"],
  "authors": [
    {
      "name": "Michael Krasselt",
      "url": "https://github.com/mkrasselt1"
    },
    {
      "name": "PepeTheFroggie",
      "url": "https://github.com/PepeTheFroggie/Victron-VE.Bus---esp32"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mkrasselt1/ve.bus-library.git"
  },
  "license": "MIT",
  "frameworks": ["arduino"],
  "platforms": ["espressif32"],
  "build": {
    "srcDir": "src"
  },
  "examples": [
    {
      "name": "Basic ESS",
      "base": "examples/basic_ess",
      "files": ["src/main.cpp", "platformio.ini"]
    }
  ]
}
